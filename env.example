# Wake Word Configuration
WAKE_WORD=jarvis
WAKE_WORD_SENSITIVITY=0.5
WAKE_WORD_MODEL=openwakeword

# Speech-to-Text
STT_PROVIDER=openai
STT_MODEL=whisper-1
OPENAI_API_KEY=your_key_here

# Language Model
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_HOST=http://localhost:11434

# Text-to-Speech
TTS_PROVIDER=piper
TTS_VOICE=en_US-ryan-high

# Audio Settings
SAMPLE_RATE=16000
CHUNK_SIZE=512
CHANNELS=1

# Debug
DEBUG=false
LOG_LEVEL=INFO